# Dependencies
node_modules/

# Python serial proxy: uv-created venv + lock + caches (the .py/pyproject/README
# are tracked; the venv is regenerated by `uv run`).
serial-proxy/.venv/
serial-proxy/uv.lock
__pycache__/
*.pyc

# Build output — fully regenerated by `bun run build` (or `build:bookmarklet`).
# The hostable dist/ is ASSEMBLED from committed data/ + the JS bundle, so it
# never needs to be tracked.
dist/

# Logs / temp
*.log
.DS_Store
.vitest/

# Playwright / e2e artifacts (screenshots + host probe dumps are regenerated)
test-results/
playwright-report/
.cache/
e2e/out/

# Local build-time data exports (reverse-engineered bundle + block export +
# HandPy skill). NOT redistributed here — only the DERIVED data/ is committed.
# Needed only to REGENERATE data/ (build:catalog|build:knowledge). See README.
vendor/

# Local secrets (never commit API keys)
.env
.env.local

# NOTE: data/ (the committed block catalog + board knowledge) is tracked on purpose.
